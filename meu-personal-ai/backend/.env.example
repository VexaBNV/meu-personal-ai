# ══════════════════════════════════════════════════════════════
# Meu Personal AI — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores reais
# NUNCA comite o arquivo .env no git
# ══════════════════════════════════════════════════════════════

# ── Servidor ───────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3000
API_PREFIX=                   # vazio em produção (api.meupersonalai.com.br)

# ── Banco de dados ─────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Pool de conexões (produção via Supabase Pooler)
DATABASE_POOL_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Redis ──────────────────────────────────────────────────────
# Upstash → Create Database → REST URL + Token
REDIS_URL=rediss://:[PASSWORD]@[HOST].upstash.io:6379

# ── Autenticação ───────────────────────────────────────────────
# JWT_SECRET: openssl rand -hex 64
JWT_SECRET=sua_string_aleatoria_de_64_chars_aqui
JWT_EXPIRES_IN=15m

# JWT_REFRESH_SECRET: openssl rand -hex 64
JWT_REFRESH_SECRET=outra_string_aleatoria_de_64_chars_aqui
JWT_REFRESH_EXPIRES_IN=30d

# ── Firebase ───────────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=meu-personal-ai
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@meu-personal-ai.iam.gserviceaccount.com
# Copie a chave privada completa (com \n literais ou entre aspas)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# ── Anthropic (IA) ─────────────────────────────────────────────
# console.anthropic.com → API Keys
LLM_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL_CHAT=claude-sonnet-4-20250514       # modelo principal
LLM_MODEL_FAST=claude-haiku-4-5-20251001      # notificações e substituições

# ── Cloudflare R2 (Storage) ────────────────────────────────────
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=meu-personal-ai-storage
R2_PUBLIC_URL=https://storage.meupersonalai.com.br   # domínio custom ou workers.dev

# ── Stripe ─────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # em desenvolvimento

# dashboard.stripe.com → Developers → Webhooks → Add endpoint
# Endpoint: https://api.meupersonalai.com.br/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs dos produtos no Stripe (dashboard.stripe.com → Products)
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ELITE_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RevenueCat ─────────────────────────────────────────────────
# app.revenuecat.com → Project → API Keys
REVENUECAT_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ───────────────────────────────────────────────────────
# URLs permitidas (separadas por vírgula)
CORS_ORIGINS=https://meupersonalai.com.br,https://admin.meupersonalai.com.br

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_TTL=60000          # janela em ms (60s)
RATE_LIMIT_MAX=100            # requisições por janela por IP

# ── Logs ───────────────────────────────────────────────────────
LOG_LEVEL=info                # debug | info | warn | error
LOG_SERVICE=meu-personal-ai
# Logtail / Better Stack (opcional)
LOGTAIL_SOURCE_TOKEN=

# ── Sentry (opcional) ──────────────────────────────────────────
SENTRY_DSN=

# ════════════════════════════════════════════════════════════════
# DESENVOLVIMENTO LOCAL — valores para rodar sem serviços externos
# ════════════════════════════════════════════════════════════════

# Para rodar local com Docker Compose:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meupersonalai
# REDIS_URL=redis://localhost:6379
